# Database URLs
REGISTRATION_DATABASE_URL=postgresql://registration_user:registration_pass@postgres-registration:5432/registration_db
MEDICAL_RECORD_DATABASE_URL=mysql+pymysql://medical_user:medical_pass@mysql-medical-record:3306/medical_db
PHARMACY_MONGODB_URL=mongodb://mongodb-pharmacy:27017/pharmacy_db
BILLING_DATABASE_URL=postgresql://billing_user:billing_pass@postgres-billing:5432/billing_db

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Queue Names
PATIENT_REGISTERED_QUEUE=patient_registered_queue
PRESCRIPTION_CREATED_QUEUE=prescription_created_queue
MEDICINE_DISPENSED_QUEUE=medicine_dispensed_queue
INVOICE_CREATED_QUEUE=invoice_created_queue

# Dead Letter Queues
DLQ_PREFIX=dlq_

# Service URLs
REGISTRATION_SERVICE_URL=http://registration-service:8000
MEDICAL_RECORD_SERVICE_URL=http://medical-record-service:8000
PHARMACY_SERVICE_URL=http://pharmacy-service:8000
BILLING_SERVICE_URL=http://billing-service:8000
